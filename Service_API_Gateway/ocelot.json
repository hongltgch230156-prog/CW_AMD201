{
  "GlobalConfiguration": {
    "BaseUrl": "https://localhost:9999"
  },
  "Routes": [
    {
      "UpstreamPathTemplate": "/gateway/url/shorten",
      "UpstreamHttpMethod": [ "Post" ],
      "DownstreamPathTemplate": "/api/url/shorten",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 3333
        }
      ],
      "RateLimitOptions": {
        "ClientWhitelist": [],
        "EnableRateLimiting": true,
        "Period": "5s",
        "PeriodTimespan": 1,
        "Limit": 5,
        "QuotaExceededMessage": "Too Many Requests",
        "HttpStatusCode": 429
      },
      "FileCacheOptions": {
        "Region": "shorten-cache",
        "TtlSeconds": 15
      }
    },
    {
      "UpstreamPathTemplate": "/gateway/url/shorten/{code}",
      "UpstreamHttpMethod": [ "Get" ],
      "DownstreamPathTemplate": "/api/url/{code}",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 3333
        }
      ],
      "RateLimitOptions": {
        "ClientWhitelist": [],
        "EnableRateLimiting": true,
        "Period": "5s",
        "PeriodTimespan": 1,
        "Limit": 5,
        "QuotaExceededMessage": "Too Many Requests",
        "HttpStatusCode": 429
      },
      "FileCacheOptions": {
        "Region": "shorten-cache",
        "TtlSeconds": 15
      }
    },

    {
      "UpstreamPathTemplate": "/gateway/url/crud",
      "UpstreamHttpMethod": [ "Get", "Post", "Delete" ],
      "DownstreamPathTemplate": "/api/url",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 2222
        }
      ],
      "RateLimitOptions": {
        "ClientWhitelist": [],
        "EnableRateLimiting": true,
        "Period": "5s",
        "PeriodTimespan": 1,
        "Limit": 5,
        "QuotaExceededMessage": "Too Many Requests",
        "HttpStatusCode": 429
      },
      "FileCacheOptions": {
        "Region": "crud-cache",
        "TtlSeconds": 15
      }
    },

    {
      "UpstreamPathTemplate": "/gateway/url/crud/{id}",
      "UpstreamHttpMethod": [ "Get", "Put", "Delete" ],
      "DownstreamPathTemplate": "/api/url/{id}",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 2222
        }
      ],
      "RateLimitOptions": {
        "ClientWhitelist": [],
        "EnableRateLimiting": true,
        "Period": "5s",
        "PeriodTimespan": 1,
        "Limit": 5,
        "QuotaExceededMessage": "Too Many Requests",
        "HttpStatusCode": 429
      },
      "FileCacheOptions": {
        "Region": "crud-cache",
        "TtlSeconds": 15
      }
    }

  ]
}